{
  "expo": {
    "name": "MilkKart",
    "slug": "milkkart-mobile",
    "scheme": "milkkart",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "primaryColor": "#3bb77e",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#def9ec"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.milkkart.app"
    },
    "android": {
      "package": "in.milkkart.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MilkKart uses your location to navigate to delivery addresses."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "cameraPermission": "MilkKart uses the camera so riders can attach a delivery proof photo.",
          "photosPermission": "MilkKart accesses your photos so riders can attach a delivery proof photo."
        }
      ]
    ]
  }
}
